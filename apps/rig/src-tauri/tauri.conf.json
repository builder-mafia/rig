{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Rig",
  "version": "26.6.231",
  "identifier": "sh.rig.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm app-frontend:dev",
    "beforeBuildCommand": "pnpm app-frontend:build"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/builder-mafia/rig/main/apps/rig/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE1N0U2MkNEQ0Q1QzQwODkKUldTSlFGek56V0orcFdlV3kxMlNCZmQ3YjN2Uktzc2ZleGRkSVIyb1ZNcVBCSUNwaDloREY4aTQK"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Rig",
        "width": 1600,
        "height": 1000,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
