# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# generated worker bundles
/public/workers/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.release.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.opencode

docs/

# local release script (contains signing/notarization secrets)
/scripts/*
!/scripts/export-env.sh
!/scripts/sync-tauri-version.mjs
!/scripts/build-prod.mjs
!/scripts/upload-release-artifacts.mjs
.env.local
