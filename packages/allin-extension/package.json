{
  "name": "@allin/extension",
  "version": "0.1.0",
  "private": false,
  "description": "this package serves extension interface to implement extensions",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "check-ts": "tsc --noEmit"
  },
  "devDependencies": {
    "@allin/api": "workspace:*"
  }
}
