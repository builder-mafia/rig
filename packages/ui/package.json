{
  "name": "@allin/ui",
  "version": "0.1.0",
  "private": false,
  "description": "UI for ALLIN",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup"
  },
  "dependencies": {
    "tailwind-merge": "catalog:tw"
  },
  "devDependencies": {
    "typescript": "catalog:types",
    "tsup": "catalog:build",
    "tailwindcss": "catalog:tw",
    "@tailwindcss/postcss": "catalog:tw"
  }
}
