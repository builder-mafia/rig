{
  "name": "@allin/chat",
  "version": "0.1.0",
  "private": false,
  "description": "Chat for ALLIN",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "pnpm run generate:model-spec && tsup --watch",
    "build": "pnpm run generate:model-spec && tsup",
    "generate:model-spec": "tsx src/provider/google/script/fetch-google-model-spec.ts && tsx src/provider/openai/script/fetch-openai-model-spec.ts && tsx src/provider/anthropic/script/fetch-anthropic-model-spec.ts",
    "check-ts": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest run --watch"
  },
  "peerDependencies": {
    "@ai-sdk/anthropic": "catalog:ai",
    "@ai-sdk/google": "catalog:ai",
    "@ai-sdk/openai": "catalog:ai",
    "@ai-sdk/provider": "catalog:ai",
    "@ai-sdk/provider-utils": "catalog:ai",
    "@ai-sdk/react": "catalog:ai",
    "ai": "catalog:ai",
    "rxjs": "catalog:utils",
    "ts-pattern": "catalog:utils",
    "uuid": "catalog:utils",
    "zod": "catalog:utils"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "catalog:ai",
    "@ai-sdk/google": "catalog:ai",
    "@ai-sdk/openai": "catalog:ai",
    "@ai-sdk/provider": "catalog:ai",
    "@ai-sdk/provider-utils": "catalog:ai",
    "@ai-sdk/react": "catalog:ai",
    "@allin/db-schema": "workspace:*",
    "@allin/message-metadata-schema": "workspace:*",
    "@types/node": "^25.0.3",
    "ai": "catalog:ai",
    "rxjs": "catalog:utils",
    "ts-pattern": "catalog:utils",
    "tsup": "catalog:build",
    "tsx": "^4.21.0",
    "typescript": "catalog:types",
    "uuid": "catalog:utils",
    "vitest": "catalog:test",
    "zod": "catalog:utils"
  }
}
