{
  "name": "@allin/utils",
  "version": "0.1.0",
  "private": false,
  "description": "Utils for ALLIN",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "check-ts": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest run --watch --passWithNoTests"
  },
  "devDependencies": {
    "typescript": "catalog:types",
    "tsup": "catalog:build",
    "vitest": "catalog:test",
    "rxjs": "catalog:utils",
    "react": "catalog:react19"
  },
  "dependencies": {
    "rxjs": "catalog:utils"
  }
}
